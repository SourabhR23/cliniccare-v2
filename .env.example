# ─────────────────────────────────────────────────────────────
# ClinicCare V2 — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ── Security ─────────────────────────────────────────────────
SECRET_KEY=your-secret-key-min-32-chars-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
WEBHOOK_SECRET=change-me-in-production

# ── Owner API Key (demo protection) ──────────────────────────
# Only you know this key. Requests without it are read-only.
OWNER_API_KEY=your-private-owner-key-here

# ── MongoDB Atlas ─────────────────────────────────────────────
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGODB_DB_NAME=cliniccare

# ── ChromaDB Cloud ────────────────────────────────────────────
CHROMA_HOST=api.trychroma.com
CHROMA_PORT=443
CHROMA_API_KEY=your-chroma-api-key
CHROMA_TENANT=your-tenant-name
CHROMA_DATABASE=cliniccare
CHROMA_COLLECTION_NAME=clinic_visits

# ── Cohere (Reranker) ──────────────────────────────────────────
# Get free key: https://dashboard.cohere.com/api-keys
# Free tier: 1000 rerank calls/month. Leave blank to skip reranking (fallback to RRF order).
COHERE_API_KEY=

# ── OpenAI / EURI ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Leave blank to use real OpenAI. Set to EURI base URL to use EURI:
# OPENAI_BASE_URL=https://api.euron.one/api/v1/euri
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_FAST_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=1000
OPENAI_EMBEDDING_DIMENSIONS=1536

# ── Redis (Upstash recommended for cloud) ─────────────────────
REDIS_URL=redis://localhost:6379
# Upstash example: rediss://:password@host.upstash.io:6379

# ── Supabase PostgreSQL (LangGraph checkpointing) ─────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ── SMTP Email (Gmail App Password recommended) ───────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=your@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your@gmail.com
SMTP_FROM_NAME=ClinicCare

# ── Celery (optional — only needed for appointment reminders) ─
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
SCHEDULING_REMINDER_CHECK_INTERVAL_MINUTES=60
